rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Emergency contacts subcollection
      match /emergency_contacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Emergency sessions - readable by anyone with the session ID (for emergency contacts)
    // This allows emergency contacts to view live location without authentication
    match /emergency_sessions/{sessionId} {
      allow read: if true; // Public read access for emergency contacts
      allow write: if request.auth != null && 
                   request.auth.uid == resource.data.userId; // Only the user can create/update
    }
    
    // Default deny all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}